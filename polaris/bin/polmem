#!/usr/bin/env python3
# polaris/bin/polmem — Polaris memory CLI for teammates (v0).
# Speaks JSON-MCP over stdin to the CURRENT repo's committed bundle
# (scripts/polaris_memory_repo.py) — zero engine duplication. Repo-scoped,
# consumer-first (D-T1). The founder's cross-repo polmem lives in the vault.
from __future__ import annotations

import argparse
import json
import subprocess
import sys
from pathlib import Path

BUNDLE_REL = Path("scripts") / "polaris_memory_repo.py"
NOT_WIRED = ("this repo is not memory-wired (no scripts/polaris_memory_repo.py) — "
             "ask Niccolò or run: polmem init")


def find_bundle(start: Path) -> Path | None:
    cur = start.resolve()
    for d in (cur, *cur.parents):
        if (d / BUNDLE_REL).is_file():
            return d / BUNDLE_REL
        if (d / ".git").exists() and not (d / BUNDLE_REL).is_file():
            return None
    return None


def _rpc_lines(tool: str, args: dict) -> str:
    init = {"jsonrpc": "2.0", "id": 1, "method": "initialize",
            "params": {"protocolVersion": "2025-06-18", "capabilities": {}}}
    call = {"jsonrpc": "2.0", "id": 2, "method": "tools/call",
            "params": {"name": tool, "arguments": args}}
    return json.dumps(init) + "\n" + json.dumps(call) + "\n"


def mcp_call(bundle: Path, tool: str, args: dict) -> tuple[str, bool]:
    proc = subprocess.run([sys.executable, str(bundle)], input=_rpc_lines(tool, args),
                          capture_output=True, text=True, cwd=str(bundle.parents[1]))
    for line in proc.stdout.splitlines():
        try:
            msg = json.loads(line)
        except json.JSONDecodeError:
            continue
        if msg.get("id") == 2:
            res = msg.get("result") or {}
            texts = [c.get("text", "") for c in res.get("content", [])]
            return "\n".join(texts), bool(res.get("isError"))
    return f"bundle produced no tools/call reply (exit {proc.returncode})", True


def _cmd_tool(tool: str, args: dict) -> int:
    bundle = find_bundle(Path.cwd())
    if bundle is None:
        print(NOT_WIRED, file=sys.stderr)
        return 1
    text, err = mcp_call(bundle, tool, args)
    print(text)
    return 1 if err else 0


def _cmd_health() -> int:
    bundle = find_bundle(Path.cwd())
    if bundle is None:
        print(NOT_WIRED, file=sys.stderr)
        return 1
    root = bundle.parents[1]
    idx = root / ".wiki" / "index.md"
    journal = root / ".wiki" / "journal"
    n_journal = len(list(journal.glob("*.md"))) if journal.is_dir() else 0
    print(f"bundle: {bundle}")
    print(f"index:  {'OK' if idx.is_file() else 'MISSING'} ({idx})")
    print(f"journal: {n_journal} entries")
    return 0


def _cmd_sync() -> int:
    print("sync: writer-side (distillation) runs on the founder machine / CI — "
          "no-op on teammate machines. Your recall reads the committed .wiki; "
          "it updates when you pull.")
    return 0


def _cmd_init(consumer: bool) -> int:
    print("polmem init (v0): consumer mode is the default for teammates — "
          "the repo's committed bundle + .mcp.json already give you recall/remember.")
    print("Writer role (distillation) stays single-writer (Niccolò's machine / CI).")
    if consumer:
        print("consumer: nothing to activate — you are read+journal only by design.")
    return 0


def main(argv: list[str]) -> int:
    p = argparse.ArgumentParser(prog="polmem", description="Polaris repo memory CLI (team v0)")
    sub = p.add_subparsers(dest="cmd", required=True)
    r = sub.add_parser("recall"); r.add_argument("query"); r.add_argument("--top", type=int, default=5)
    m = sub.add_parser("remember"); m.add_argument("text")
    sub.add_parser("health")
    sub.add_parser("sync")
    i = sub.add_parser("init"); i.add_argument("--consumer", action="store_true")
    try:
        a = p.parse_args(argv)
    except SystemExit as e:
        return int(e.code or 0)
    if a.cmd == "recall":
        return _cmd_tool("recall", {"query": a.query, "top": a.top})
    if a.cmd == "remember":
        # live bundles (scripts/polaris_memory_repo.py) require title+body, not
        # a flat "text" — send both shapes; each bundle reads what it needs.
        return _cmd_tool("remember", {"text": a.text, "title": a.text[:60].strip(), "body": a.text})
    if a.cmd == "health":
        return _cmd_health()
    if a.cmd == "sync":
        return _cmd_sync()
    return _cmd_init(a.consumer)


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
